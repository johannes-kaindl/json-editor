{
  "name": "obsidian-json-editor",
  "version": "1.5.0",
  "description": "View and edit JSON files in Obsidian with a Tree/Source toggle. Renders json code blocks in Markdown notes as collapsible theme-aware trees.",
  "main": "main.js",
  "author": {
    "name": "Johannes Kaindl",
    "url": "https://codeberg.org/jkaindl"
  },
  "license": "AGPL-3.0-or-later",
  "homepage": "https://codeberg.org/jkaindl/json-editor",
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/jkaindl/json-editor.git"
  },
  "bugs": {
    "url": "https://codeberg.org/jkaindl/json-editor/issues"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -p tsconfig.build.json -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "deploy": "npm run build && cp main.js manifest.json styles.css \"${OBSIDIAN_PLUGIN_DIR:?Set OBSIDIAN_PLUGIN_DIR to <vault>/.obsidian/plugins/obsidian-json-editor}\"/"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "obsidian-md",
    "json",
    "json-editor",
    "json-viewer",
    "tree-view",
    "codemirror",
    "codemirror6",
    "typescript",
    "markdown",
    "editor",
    "plugin"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.1",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.21.0",
    "happy-dom": "^14.10.0",
    "obsidian": "^1.4.16",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
